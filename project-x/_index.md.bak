<div id="app-modal" class="app-modal">
<div class="app-window" id="app-window">
<div class="app-bracket tl"></div><div class="app-bracket tr"></div>
<div class="app-bracket bl"></div><div class="app-bracket br"></div>
<div class="app-header">
<div class="app-title-area">
<span class="app-title-id" id="modal-app-id">MODULE_000</span>
<span class="app-title-name" id="modal-app-title">SYSTEM MODULE</span>
</div>
<button class="app-close-btn" onclick="closeApp()">[ DISCONNECT ]</button>
</div>
<div class="app-body" id="modal-app-body">
</div>
</div>
</div>

<div class="sr-footer">
<a href="/" class="sr-footer-link">RETURN TO SURFACE</a>
</div>
</div>
</div>

<script>
function initializeSystem() {
  // Move layers to proper alignment
  const bg = document.querySelector('.sr-bg');
  const grid = document.querySelector('.sr-grid');
  const scanline = document.querySelector('.sr-scanline');
  const vignette = document.querySelector('.sr-vignette');
  const lock = document.getElementById('sr-lock');
  const hub = document.getElementById('sr-hub');
  const particles = document.querySelectorAll('.sr-particle');
  [bg, grid, scanline, vignette, lock, hub].forEach(el => { if (el) document.body.appendChild(el); });
  particles.forEach(el => document.body.appendChild(el));
  // Hide external elements
  const KEEP = {'HEADER':1,'STYLE':1,'LINK':1,'SCRIPT':1,'NOSCRIPT':1,'META':1};
  Array.from(document.body.children).forEach(el => {
    const ours = el.classList.contains('sr-bg') || el.classList.contains('sr-grid') ||
                 el.classList.contains('sr-scanline') || el.classList.contains('sr-vignette') ||
                 el.classList.contains('sr-particle') || el.id === 'sr-lock' || el.id === 'sr-hub';
    if (!ours && !KEEP[el.tagName]) el.style.setProperty('display','none','important');
  });
  // === 6-DIGIT PIN AUTH MECHANISM ===
  const TARGET_PIN = "210723";
  let inputCode = "";
  let failCount = 0;
  let lockoutUntil = 0;
  const displayEl = document.getElementById('code-display');
  const digits = displayEl.querySelectorAll('.code-digit');
  const msgEl = document.getElementById('lock-msg');
  const lockoutEl = document.getElementById('code-lockout');
  const hubEl = document.getElementById('sr-hub');
  const lockScreen = document.getElementById('sr-lock');
  const updatePINDisplay = () => {
    digits.forEach((d, i) => {
      d.textContent = i < inputCode.length ? '●' : '';
      d.classList.toggle('filled', i < inputCode.length);
    });
  };
  const showLockMessage = (text, isSuccess) => {
    msgEl.textContent = text;
    msgEl.classList.add('show');
    if (isSuccess) msgEl.classList.add('success');
    else msgEl.classList.remove('success');
  };
  const checkLockout = () => {
    if (Date.now() < lockoutUntil) {
      let remaining = Math.ceil((lockoutUntil - Date.now()) / 1000);
      lockoutEl.style.display = 'block';
      lockoutEl.textContent = 'SYSTEM LOCKOUT: ' + remaining + 's REMAINING';
      return true;
    }
    lockoutEl.style.display = 'none';
    return false;
  };
  const verifyPIN = () => {
    if (checkLockout()) { inputCode = ''; updatePINDisplay(); return; }
    if (inputCode === TARGET_PIN) {
      digits.forEach(d => { d.classList.add('success'); });
      showLockMessage('> ACCESS GRANTED', true);
      failCount = 0;
      setTimeout(() => {
        lockScreen.classList.add('unlocked');
        hubEl.classList.add('unlocked');
        runBoot();
      }, 500);
    } else {
      digits.forEach(d => { d.classList.add('error'); });
      showLockMessage('> INVALID ACCESS CODE', false);
      failCount++;
      if (failCount >= 3) {
        lockoutUntil = Date.now() + 30000;
        showLockMessage('> SECURITY LOCKOUT ACTIVATED', false);
      }
      setTimeout(() => {
        inputCode = '';
        updatePINDisplay();
        digits.forEach(d => { d.classList.remove('error'); });
        msgEl.classList.remove('show');
        checkLockout();
      }, 1200);
    }
  };
  // Keypad processing interface
  document.getElementById('code-keypad').addEventListener('click', function(e) {
    const btn = e.target.closest('.code-key');
    if (!btn) return;
    if (checkLockout()) return;
    const val = btn.dataset.v;
    if (val === 'clear') { inputCode = ''; updatePINDisplay(); }
    else if (val === 'back') { inputCode = inputCode.slice(0, -1); updatePINDisplay(); }
    else if (inputCode.length < 6) {
      inputCode += val;
      updatePINDisplay();
      if (inputCode.length === 6) setTimeout(verifyPIN, 200);
    }
  });
  // Keyboard processing link
  document.addEventListener('keydown', function(e) {
    if (lockScreen.classList.contains('unlocked')) return;
    if (checkLockout()) return;
    if (e.key >= '0' && e.key <= '9' && inputCode.length < 6) {
      inputCode += e.key; updatePINDisplay();
      if (inputCode.length === 6) setTimeout(verifyPIN, 200);
    } else if (e.key === 'Backspace') {
      inputCode = inputCode.slice(0, -1); updatePINDisplay();
    } else if (e.key === 'Escape') {
      inputCode = ''; updatePINDisplay();
    }
  });
  setInterval(checkLockout, 1000);
  // === Boot Sequence ===
  const bootEl = document.getElementById('sr-boot');
  const bootLines = [
    'INITIALIZING SECURE SUBSYSTEM...',
    'LOADING ENCRYPTED MODULES...',
    'VERIFYING CLEARANCE LEVEL...',
    'DECRYPTING ACCESS NODES...',
    'ALL SYSTEMS OPERATIONAL.'
  ];
  const runBoot = () => {
    let i = 0;
    const next = () => {
      if (i >= bootLines.length) {
        bootEl.classList.remove('active');
        bootEl.classList.add('fade');
        return;
      }
      bootEl.textContent = '> ' + bootLines[i];
      bootEl.classList.remove('active');
      void bootEl.offsetWidth;
      bootEl.classList.add('active');
      i++;
      setTimeout(next, 400);
    };
    next();
  };
  // === Uptime Counter ===
  const start = Date.now();
  setInterval(() => {
    const s = Math.floor((Date.now() - start) / 1000);
    const el = document.getElementById('sr-uptime');
    if (el) el.textContent =
      String(Math.floor(s/3600)).padStart(2,'0') + ':' +
      String(Math.floor((s%3600)/60)).padStart(2,'0') + ':' +
      String(s%60).padStart(2,'0');
  }, 1000);
  // === Matrix code shifting text effect ===
  const glitchTargets = document.querySelectorAll('.sr-panel-id, .sr-classification');
  glitchTargets.forEach(target => {
    const orig = target.textContent;
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&_';
    let iter = 0;
    const iv = setInterval(() => {
      target.textContent = orig.split('').map((ch, idx) => {
        if (idx < iter) return orig[idx];
        if (ch === ' ' || ch === '─' || ch === '▲') return ch;
        return chars[Math.floor(Math.random() * chars.length)];
      }).join('');
      if (iter >= orig.length) clearInterval(iv);
      iter += 0.5;
    }, 30);
  });
  // ==========================================
  // === MODULES CORE CONSOLES SYSTEM ===
  // ==========================================
  const modalEl = document.getElementById('app-modal');
  const windowEl = document.getElementById('app-window');
  const bodyEl = document.getElementById('modal-app-body');
  const modalIdEl = document.getElementById('modal-app-id');
  const modalTitleEl = document.getElementById('modal-app-title');
  // Proof Archive Database Array
  const PROOFS_DB = [
    { id: 1, title: "級数等式 \\sum_{k=1}^{\\infty}\\frac{(3^k-1)\\zeta(k+1)}{4^k} = \\pi", field: "解析学", difficulty: 3, link: "/posts/2025-12-10-proof1/", formula: "\\sum_{k=1}^{\\infty} \\frac{(3^k - 1)\\zeta(k+1)}{4^k} = \\pi", summary: "ゼータ関数の積分表示と指数関数のマクローリン展開を応用し、ゼータ級数を円周率 \\pi に収束させる極めて美しい等式。" },
    { id: 2, title: "級数等式 \\sum_{n=0}^{\\infty}\\frac{\\zeta(2n+2)}{16^n} = 8 - 2\\pi", field: "解析学", difficulty: 3, link: "/posts/2025-12-10-proof2/", formula: "\\sum_{n=0}^{\\infty} \\frac{\\zeta(2n+2)}{16^n} = 8 - 2\\pi", summary: "偶数ゼータ関数と 16^{-n} の積の無限和が、円周率を含む有理数表現に収束する。sinhの展開と部分分数分解を使用。" },
    { id: 3, title: "級数等式 \\sum_{n=0}^{\\infty}\\frac{\\delta(n) (-1)^n(n+2)(n+3)\\zeta(n+4)}{2^n} = 32 - 24\\zeta(3)", field: "解析学", difficulty: 4, link: "/posts/2025-12-11-proof3/", formula: "\\sum_{n=0}^{\\infty} \\frac{(-1)^n(n+2)(n+3)\\zeta(n+4)}{2^n} = 32 - 24\\zeta(3)", summary: "交代級数と多項式係数、ゼータ関数の積の和。アペリーの定数 \\zeta(3) の奇数項分解を利用する高度な評価。" },
    { id: 4, title: "定積分 \\int_{0}^{\\frac{1}{2}} \\ln \\Gamma (x + \\frac{1}{8}) dx = ...", field: "解析学", difficulty: 5, link: "/posts/2025-12-14-proof4/", formula: "\\int_{0}^{\\frac{1}{2}} \\ln \\Gamma \\left( x + \\frac{1}{8} \\right) dx = \\frac{1}{4}\\ln(2\\pi) - \\frac{1}{4\\pi} \\left( Cl_2\\left(\\frac{\\pi}{4}\right) + Cl_2\\left(\\frac{3\\pi}{4}\right) \\right)", summary: "対数ガンマ関数の区間定積分。クンマーのフーリエ級数展開を用いて、クラウゼン関数 Cl_2(\\theta) に帰着させる難関証明。" },
    { id: 5, title: "母関数等式 \\sum_{n=0}^{\\infty} x^{2n} \\zeta(2+2n) = ...", field: "解析学", difficulty: 3, link: "/posts/2025-12-14-proof5/", formula: "\\sum_{n=0}^{\\infty} x^{2n} \\zeta(2+2n) = \\frac{1 - \\pi x \\ cot(\\pi x)}{2x^2} \\quad (|x| < 1)", summary: "偶数ゼータ関数の母関数が余接関数 \\cot(\\pi x) の部分分数展開に一致することを示す美しい等式。" },
    { id: 6, title: "定積分 \\int_{0}^{\\frac{\\pi}{2}} \\ln^2 \\sin x dx = ...", field: "解析学", difficulty: 4, link: "/posts/2025-12-14-proof6/", formula: "\\int_{0}^{\\frac{\\pi}{2}} \\ln^2 \\sin x \\, dx = \\frac{\\pi \\ln^2 2}{2} + \\frac{\\pi^3}{24}", summary: "対数正弦の二乗積分。\\ln(2\\sin x) のフーリエ展開と三角関数の直交性を巧みに用いてバーゼル問題に帰着。" },
    { id: 10, title: "級数等式 \\sum_{n \\ge 0} \\frac{1}{(2n+1)^2} = \\frac{\\pi^2}{8}", field: "解析学", difficulty: 2, link: "/posts/2025-12-25-proof10/", formula: "\\sum_{n \\ge 0} \\frac{1}{(2n+1)^2} = \\frac{\\pi^2}{8}", summary: "奇数の逆二乗和の極限。複素対数の積分による美しい直接証明。バーゼル問題の派生。" },
    { id: 11, title: "入れ子積分 \\int_{0}^{\\frac{\\pi}{2}} \\sin(x \\sin(x \\sin ...)) dx = ...", field: "解析学", difficulty: 5, link: "/posts/2026-01-14-proof11/", formula: "\\int_{0}^{\\frac{\\pi}{2}} \\sin(x \\sin(x \\sin \\dots)) \\, dx = \\frac{\\pi}{2}(1 - \\log 2)", summary: "無限の入れ子構造（自己相似構造）を持つ関数の定積分。逆関数への置換と部分積分により、対数正弦積分に帰着。" }
  ];
  window.openApp = (appId) => {
    modalEl.style.display = 'flex';
    modalEl.classList.add('active');
    windowEl.style.setProperty('--accent', 'var(--cyan)');
    modalIdEl.style.borderColor = 'rgba(0, 243, 255, 0.3)';
    modalIdEl.style.color = 'var(--pink)';
    modalTitleEl.style.color = '#fff';
    if (appId === 'proof-archive') {
      windowEl.style.setProperty('--accent', 'var(--cyan)');
      modalIdEl.textContent = 'MODULE_004';
      modalTitleEl.textContent = 'PROOF ARCHIVE // 構造化証明アーカイブ';
      initProofArchive();
    } else if (appId === 'password-generator') {
      windowEl.style.setProperty('--accent', 'var(--pink)');
      modalIdEl.textContent = 'MODULE_005';
      modalIdEl.style.color = 'var(--cyan)';
      modalIdEl.style.borderColor = 'rgba(0, 243, 255, 0.3)';
      modalTitleEl.textContent = 'PASS GENERATOR // タクティカル暗号鍵生成システム';
      initPasswordGenerator();
    } else if (appId === 'steganography') {
      windowEl.style.setProperty('--accent', 'var(--green)');
      modalIdEl.textContent = 'MODULE_006';
      modalTitleEl.textContent = 'STEGANO TOOL // 画像内隠蔽通信システム';
      initSteganography();
    }
    if (navigator.vibrate) navigator.vibrate(30);
  };
  window.closeApp = () => {
    modalEl.classList.remove('active');
    modalEl.style.display = 'none';
    bodyEl.innerHTML = '';
  };
  modalEl.addEventListener('click', (e) => { if (e.target === modalEl) closeApp(); });
  // --- PROOF ARCHIVE ENGINE ---
  function initProofArchive() {
    bodyEl.innerHTML = `
      <div class="pa-filter-bar">
        <input type="text" id="pa-search" class="pa-search-input" placeholder="定理・手法・キーワードを入力...">
        <select id="pa-difficulty" class="pa-select">
          <option value="">難易度: すべて</option>
          <option value="2">★2 (標準)</option>
          <option value="3">★3 (応用)</option>
          <option value="4">★4 (上級)</option>
          <option value="5">★5 (極限)</option>
        </select>
      </div>
      <div class="pa-grid" id="pa-grid"></div>
    `;
    const searchInput = document.getElementById('pa-search');
    const diffSelect = document.getElementById('pa-difficulty');
    const render = () => {
      const query = searchInput.value.toLowerCase();
      const diff = diffSelect.value;
      const grid = document.getElementById('pa-grid');
      const filtered = PROOFS_DB.filter(item => {
        return (item.title.toLowerCase().includes(query) || item.summary.toLowerCase().includes(query) || item.field.toLowerCase().includes(query)) && (diff === "" || item.difficulty === parseInt(diff));
      });
      if (filtered.length === 0) {
        grid.innerHTML = `<div style="text-align:center; padding: 2rem; color: rgba(0,243,255,0.4); font-family:'Share Tech Mono', monospace;">> NO COMPATIBLE ARCHIVES FOUND.</div>`;
        return;
      }
      grid.innerHTML = filtered.map(item => `
        <div class="pa-card">
          <div class="pa-card-header">
            <h4 class="pa-card-title">Proof#${item.id}: ${item.title}</h4>
            <div class="pa-card-meta">
              <span class="pa-badge field">${item.field}</span>
              <span class="pa-badge difficulty">Level ${'★'.repeat(item.difficulty)}</span>
            </div>
          </div>
          <div class="pa-card-formula">$$${item.formula}$$</div>
          <div class="pa-card-desc">${item.summary}</div>
          <a href="${item.link}" class="pa-card-btn">> ACCESS ARCHIVE LOG</a>
        </div>
      `).join('');
      if (window.MathJax) {
        if (typeof MathJax.typesetPromise === 'function') MathJax.typesetPromise();
        else if (typeof MathJax.Hub === 'object' && typeof MathJax.Hub.Queue === 'function') MathJax.Hub.Queue(["Typeset", MathJax.Hub, grid]);
      }
    };
    searchInput.addEventListener('input', render);
    diffSelect.addEventListener('change', render);
    render();
  }
  // --- PASSWORD GENERATOR ENGINE ---
  let genHistory = [];
  function initPasswordGenerator() {
    bodyEl.innerHTML = `
      <div class="pg-container">
        <div class="pg-panel">
          <div class="pg-display-box">
            <div id="pg-display" class="pg-display">-- SELECT SYSTEM KEY --</div>
            <button id="pg-copy" class="pg-copy-btn" disabled>COPY</button>
          </div>
          <div class="pg-slider-group">
            <div class="pg-label"><span>KEY LENGTH</span><span class="value" id="pg-len-val">16</span></div>
            <input type="range" id="pg-len" class="pg-slider" min="8" max="64" value="16">
          </div>
          <div class="pg-options">
            <label class="pg-checkbox-label"><input type="checkbox" id="pg-opt-upper" checked><div class="pg-custom-box"></div><span>A-Z (UPPERCASE)</span></label>
            <label class="pg-checkbox-label"><input type="checkbox" id="pg-opt-lower" checked><div class="pg-custom-box"></div><span>a-z (LOWERCASE)</span></label>
            <label class="pg-checkbox-label"><input type="checkbox" id="pg-opt-num" checked><div class="pg-custom-box"></div><span>0-9 (NUMBERS)</span></label>
            <label class="pg-checkbox-label"><input type="checkbox" id="pg-opt-sym" checked><div class="pg-custom-box"></div><span>[!@#$...] (SYMBOLS)</span></label>
            <label class="pg-checkbox-label"><input type="checkbox" id="pg-opt-cyber"><div class="pg-custom-box"></div><span>[☣☠☯⚡...] (CYBER)</span></label>
            <label class="pg-checkbox-label"><input type="checkbox" id="pg-opt-math"><div class="pg-custom-box"></div><span>[∫∑√∂...] (MATH)</span></label>
          </div>
          <button id="pg-generate" class="pg-gen-btn">GENERATE SECURE KEY</button>
        </div>
        <div class="pg-stats-panel">
          <div class="pg-stat-card"><span class="pg-stat-title">ENTROPY STRENGTH</span><span class="pg-stat-val" id="pg-entropy">0 bits</span><div class="pg-meter-bg"><div id="pg-entropy-bar" class="pg-meter-fill"></div></div></div>
          <div class="pg-stat-card"><span class="pg-stat-title">SECURITY LEVEL</span><span class="pg-stat-val" id="pg-sec-level">--</span></div>
          <div class="pg-stat-card"><span class="pg-stat-title">DECRYPTION TIME</span><span class="pg-stat-val" id="pg-crack-time">--</span></div>
          <div class="pg-stat-card" style="flex:1; min-height:120px;"><span class="pg-stat-title">LOCAL KEY LOGS</span><div class="pg-logs" id="pg-logs-area"><div style="opacity:0.3;">> STANDBY. LOG IS EMPTY.</div></div></div>
        </div>
      </div>
    `;
    const lengthSlider = document.getElementById('pg-len');
    const lengthVal = document.getElementById('pg-len-val');
    const generateBtn = document.getElementById('pg-generate');
    const copyBtn = document.getElementById('pg-copy');
    const displayBox = document.getElementById('pg-display');
    const logsArea = document.getElementById('pg-logs-area');
    lengthSlider.addEventListener('input', () => { lengthVal.textContent = lengthSlider.value; });
    copyBtn.addEventListener('click', () => {
      if (displayBox.textContent && displayBox.textContent !== '-- SELECT SYSTEM KEY --') {
        navigator.clipboard.writeText(displayBox.textContent).then(() => {
          const original = copyBtn.textContent; copyBtn.textContent = 'COPIED';
          copyBtn.style.color = 'var(--green)'; copyBtn.style.borderColor = 'var(--green)';
          setTimeout(() => { copyBtn.textContent = original; copyBtn.style.color = ''; copyBtn.style.borderColor = ''; }, 1000);
        });
      }
    });
    generateBtn.addEventListener('click', () => {
      const len = parseInt(lengthSlider.value);
      let charset = ''; let poolSize = 0;
      if (document.getElementById('pg-opt-upper').checked) { charset += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'; poolSize += 26; }
      if (document.getElementById('pg-opt-lower').checked) { charset += 'abcdefghijklmnopqrstuvwxyz'; poolSize += 26; }
      if (document.getElementById('pg-opt-num').checked) { charset += '0123456789'; poolSize += 10; }
      if (document.getElementById('pg-opt-sym').checked) { charset += '!@#$%^&*()_+-=[]{}|;:,.<>?'; poolSize += 26; }
      if (document.getElementById('pg-opt-cyber').checked) { charset += '☣☠☯⚡ΞΨΦΩ★☢❄☄💧🔥'; poolSize += 16; }
      if (document.getElementById('pg-opt-math').checked) { charset += '∫∑√∂π∞±≠≈≡≤≥∝'; poolSize += 13; }
      if (charset === '') { displayBox.textContent = 'ERROR: SELECT CHAR TYPE'; return; }
      generateBtn.disabled = true;
      let elapsed = 0;
      const spin = setInterval(() => {
        let temp = ''; for (let i = 0; i < len; i++) temp += charset.charAt(Math.floor(Math.random() * charset.length));
        displayBox.textContent = temp; displayBox.style.color = 'var(--pink)';
        elapsed += 30;
        if (elapsed >= 300) { clearInterval(spin); finalizePassword(charset, poolSize, len); }
      }, 30);
    });
    function finalizePassword(charset, poolSize, len) {
      let finalPass = ''; const array = new Uint32Array(len); window.crypto.getRandomValues(array);
      for (let i = 0; i < len; i++) finalPass += charset.charAt(array[i] % charset.length);
      displayBox.textContent = finalPass; displayBox.style.color = 'var(--green)';
      copyBtn.disabled = false; generateBtn.disabled = false;
      const entropy = Math.round(len * Math.log2(poolSize));
      document.getElementById('pg-entropy').textContent = `${entropy} bits`;
      const bar = document.getElementById('pg-entropy-bar');
      const secLevel = document.getElementById('pg-sec-level');
      bar.style.width = `${Math.min(100, (entropy / 160) * 100)}%`;
      if (entropy < 60) { secLevel.textContent = 'WEAK // 低保護強度'; secLevel.className = 'pg-stat-val danger'; bar.style.backgroundColor = 'var(--pink)'; }
      else if (entropy < 100) { secLevel.textContent = 'STANDARD // 標準保護強度'; secLevel.className = 'pg-stat-val warning'; bar.style.backgroundColor = 'var(--amber)'; }
      else { secLevel.textContent = 'MILITARY_GRADE // 軍用最高暗号強度'; secLevel.className = 'pg-stat-val secure'; bar.style.backgroundColor = 'var(--green)'; }
      const guesses = Math.pow(poolSize, len); const seconds = guesses / 1e12;
      const timeVal = document.getElementById('pg-crack-time');
      if (seconds < 1) timeVal.textContent = '0.001 seconds (Instant)';
      else if (seconds < 86400) timeVal.textContent = 'A few hours (Medium Threat)';
      else if (seconds < 31536000) timeVal.textContent = 'A few months (Highly Secure)';
      else { const years = Math.round(seconds / 31536000); timeVal.textContent = years > 1e10 ? 'Infinite (Universe-level Age)' : `${years.toLocaleString()} years`; }
      const time = new Date().toLocaleTimeString(); genHistory.unshift({ time, pass: finalPass });
      if (genHistory.length > 8) genHistory.pop();
      logsArea.innerHTML = genHistory.map((item, idx) => `<div class="pg-log-entry" onclick="copyFromLog(${idx})"><span><span class="pg-log-time">[${item.time}]</span> ${item.pass.substring(0, 18)}...</span><span style="color:var(--cyan); font-size:0.55rem;">[COPY]</span></div>`).join('');
    }
  }
  window.copyFromLog = (idx) => { if (genHistory[idx]) { navigator.clipboard.writeText(genHistory[idx].pass); if (navigator.vibrate) navigator.vibrate(20); } };
  // --- STEGANOGRAPHY ENGINE ---
  let stegImg = null; let stegEncodedUrl = null;
  function initSteganography() {
    stegImg = null; stegEncodedUrl = null;
    bodyEl.innerHTML = `
      <div class="steg-tabs">
        <button class="steg-tab active" id="tab-steg-enc" onclick="switchStegTab('enc')">ENCODE // 秘密埋め込み</button>
        <button class="steg-tab" id="tab-steg-dec" onclick="switchStegTab('dec')">DECODE // 秘密抽出</button>
      </div>
      <div class="steg-pane active" id="pane-steg-enc">
        <div class="steg-row">
          <div class="steg-input-group"><span class="pg-stat-title">STEP 1: CARRIER IMAGE (原画)</span><div class="steg-upload-zone" onclick="document.getElementById('steg-file-enc').click()"><svg viewBox="0 0 48 48"><rect x="6" y="8" width="36" height="32" rx="3"/><circle cx="16" cy="18" r="4"/><path d="M6 32l10-10 12 12 4-4 10 10"/></svg><div class="steg-upload-text">DRAG & DROP IMAGE OR CLICK TO SELECT</div><input type="file" id="steg-file-enc" style="display:none;" accept="image/*"></div><div id="steg-enc-alert" class="steg-alert" style="display:none;"></div></div>
          <div class="steg-input-group"><span class="pg-stat-title">IMAGE PREVIEW (プレビュー)</span><div class="steg-preview-box"><img id="steg-prev-enc" class="steg-preview-img" style="display:none;"><span id="steg-holder-enc" class="steg-preview-placeholder">> CARRIER SIGNAL OFFLINE</span></div></div>
        </div>
        <div class="steg-input-group"><span class="pg-stat-title">STEP 2: ENCRYPTED MESSAGE (埋め込む秘密メッセージ)</span><textarea id="steg-msg" class="steg-textarea" placeholder="ここに極秘テキストを入力してください..."></textarea></div>
        <button id="steg-run-enc" class="steg-btn" disabled>EXECUTE ENCODE MODULE</button>
        <div class="steg-input-group" id="steg-result-area" style="display:none;"><span class="pg-stat-title">STEP 3: DEPLOYMENT READY (生成完了)</span><div style="display:flex; gap: 1rem; align-items:center;"><div class="steg-preview-box" style="flex:1; height:120px;"><img id="steg-final-img" class="steg-preview-img"></div><a id="steg-download" class="steg-btn steg-dl-btn" style="flex:1; line-height:3;" href="#" download="steg_secured.png">DOWNLOAD SECURED IMAGE</a></div></div>
      </div>
      <div class="steg-pane" id="pane-steg-dec">
        <div class="steg-row">
          <div class="steg-input-group"><span class="pg-stat-title">STEP 1: TARGET IMAGE (解析画像の取り込み)</span><div class="steg-upload-zone" onclick="document.getElementById('steg-file-dec').click()"><svg viewBox="0 0 48 48"><rect x="6" y="8" width="36" height="32" rx="3"/><path d="M14 26 L24 16 L34 26 M24 16 L24 38"/></svg><div class="steg-upload-text">SELECT SECURED SIGNAL CARRIER PNG</div><input type="file" id="steg-file-dec" style="display:none;" accept="image/*"></div></div>
          <div class="steg-input-group"><span class="pg-stat-title">IMAGE SIGNAL SCANNER (スキャン)</span><div class="steg-preview-box"><img id="steg-prev-dec" class="steg-preview-img" style="display:none;"><span id="steg-holder-dec" class="steg-preview-placeholder">> ANALYZING TARGET SIGNAL OFFLINE</span></div></div>
        </div>
        <button id="steg-run-dec" class="steg-btn" style="--accent: var(--green);" disabled>RUN MULTI-CHANNEL SCANNER</button>
        <div class="steg-input-group"><span class="pg-stat-title">RESTORED MESSAGE DATA (抽出完了)</span><div id="steg-result-dec" class="steg-decode-result">> WAITING FOR STABILIZATION SCANS...</div></div>
      </div>
    `;
    const fileEnc = document.getElementById('steg-file-enc'); const fileDec = document.getElementById('steg-file-dec');
    const prevEnc = document.getElementById('steg-prev-enc'); const prevDec = document.getElementById('steg-prev-dec');
    const holderEnc = document.getElementById('steg-holder-enc'); const holderDec = document.getElementById('steg-holder-dec');
    const runEncBtn = document.getElementById('steg-run-enc'); const runDecBtn = document.getElementById('steg-run-dec');
    const encAlert = document.getElementById('steg-enc-alert');
    document.querySelectorAll('.steg-upload-zone').forEach(zone => {
      zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.style.borderColor = 'var(--cyan)'; });
      zone.addEventListener('dragleave', () => { zone.style.borderColor = ''; });
      zone.addEventListener('drop', (e) => {
        e.preventDefault(); zone.style.borderColor = ''; const files = e.dataTransfer.files;
        if (files.length > 0) { const input = zone.querySelector('input[type="file"]'); input.files = files; input.dispatchEvent(new Event('change')); }
      });
    });
    fileEnc.addEventListener('change', () => {
      const file = fileEnc.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (e) => {
          stegImg = new Image(); stegImg.onload = () => { prevEnc.src = e.target.result; prevEnc.style.display = 'block'; holderEnc.style.display = 'none'; runEncBtn.disabled = false; encAlert.style.display = 'none'; };
          stegImg.src = e.target.result;
        };
        reader.readAsDataURL(file);
      }
    });
    fileDec.addEventListener('change', () => {
      const file = fileDec.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = (e) => {
          stegImg = new Image(); stegImg.onload = () => { prevDec.src = e.target.result; prevDec.style.display = 'block'; holderDec.style.display = 'none'; runDecBtn.disabled = false; };
          stegImg.src = e.target.result;
        };
        reader.readAsDataURL(file);
      }
    });
    runEncBtn.addEventListener('click', () => {
      const msg = document.getElementById('steg-msg').value;
      if (!msg) { encAlert.textContent = 'ERROR: SECRET TEXT CANNOT BE BLANK.'; encAlert.style.display = 'block'; return; }
      const canvas = document.createElement('canvas'); const ctx = canvas.getContext('2d');
      canvas.width = stegImg.width; canvas.height = stegImg.height; ctx.drawImage(stegImg, 0, 0);
      const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height); const data = imgData.data;
      const encoder = new TextEncoder(); const msgBytes = encoder.encode(msg); const msgLength = msgBytes.length;
      const headerBytes = new Uint8Array(4);
      headerBytes[0] = (msgLength >> 24) & 0xFF; headerBytes[1] = (msgLength >> 16) & 0xFF; headerBytes[2] = (msgLength >> 8) & 0xFF; headerBytes[3] = msgLength & 0xFF;
      const totalBytes = new Uint8Array(headerBytes.length + msgBytes.length); totalBytes.set(headerBytes, 0); totalBytes.set(msgBytes, headerBytes.length);
      if (totalBytes.length * 8 > data.length) { encAlert.textContent = 'ERROR: PIXEL CAPACITY EXCEEDED. CHOOSE LARGER IMAGE.'; encAlert.style.display = 'block'; return; }
      runEncBtn.disabled = true; runEncBtn.textContent = 'CALCULATING QUANTUM VECTORS...';
      setTimeout(() => {
        let byteIdx = 0; let bitIdx = 0;
        for (let i = 0; i < totalBytes.length * 8; i++) {
          const bit = (totalBytes[byteIdx] >> (7 - bitIdx)) & 1;
          data[i] = (data[i] & 0xFE) | bit; bitIdx++; if (bitIdx === 8) { bitIdx = 0; byteIdx++; }
        }
        ctx.putImageData(imgData, 0, 0); stegEncodedUrl = canvas.toDataURL("image/png");
        document.getElementById('steg-final-img').src = stegEncodedUrl; document.getElementById('steg-download').href = stegEncodedUrl;
        document.getElementById('steg-result-area').style.display = 'block'; runEncBtn.disabled = false; runEncBtn.textContent = 'EXECUTE ENCODE MODULE';
        if (navigator.vibrate) navigator.vibrate([30, 30, 30]);
      }, 500);
    });
    runDecBtn.addEventListener('click', () => {
      const canvas = document.createElement('canvas'); const ctx = canvas.getContext('2d');
      canvas.width = stegImg.width; canvas.height = stegImg.height; ctx.drawImage(stegImg, 0, 0);
      const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height); const data = imgData.data;
      const resultBox = document.getElementById('steg-result-dec');
      resultBox.classList.remove('error'); resultBox.textContent = 'INITIALIZING DEEP CORE SCANNER...';
      runDecBtn.disabled = true;
      setTimeout(() => {
        try {
          let lengthBytes = new Uint8Array(4); let byteIdx = 0; let bitIdx = 0;
          for (let i = 0; i < 32; i++) {
            const bit = data[i] & 1; lengthBytes[byteIdx] = (lengthBytes[byteIdx] << 1) | bit;
            bitIdx++; if (bitIdx === 8) { bitIdx = 0; byteIdx++; }
          }
          const msgLength = (lengthBytes[0] << 24) | (lengthBytes[1] << 16) | (lengthBytes[2] << 8) | lengthBytes[3];
          if (msgLength <= 0 || msgLength * 8 + 32 > data.length) throw new Error("SECRET SIGNATURE NOT DETECTED.");
          const msgBytes = new Uint8Array(msgLength); byteIdx = 0; bitIdx = 0;
          for (let i = 32; i < 32 + msgLength * 8; i++) {
            const bit = data[i] & 1; msgBytes[byteIdx] = (msgBytes[byteIdx] << 1) | bit;
            bitIdx++; if (bitIdx === 8) { bitIdx = 0; byteIdx++; }
          }
          const decoder = new TextDecoder(); const restoredText = decoder.decode(msgBytes);
          resultBox.textContent = ''; let typeIdx = 0; const speed = restoredText.length > 100 ? 5 : 20;
          const type = setInterval(() => {
            resultBox.textContent += restoredText.charAt(typeIdx); typeIdx++;
            if (typeIdx >= restoredText.length) { clearInterval(type); runDecBtn.disabled = false; }
          }, speed);
          if (navigator.vibrate) navigator.vibrate([100, 50, 100]);
        } catch (err) {
          resultBox.textContent = `CRITICAL_ERROR: ${err.message}`; resultBox.classList.add('error'); runDecBtn.disabled = false;
        }
      }, 800);
    });
  }
  window.switchStegTab = (tab) => {
    document.querySelectorAll('.steg-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.steg-pane').forEach(p => p.classList.remove('active'));
    if (tab === 'enc') { document.getElementById('tab-steg-enc').classList.add('active'); document.getElementById('pane-steg-enc').classList.add('active'); }
    else { document.getElementById('tab-steg-dec').classList.add('active'); document.getElementById('pane-steg-dec').classList.add('active'); }
  };
  console.log('%c SYSTEM PIN INITIALIZATION COMPLETE ', 'background: #ff0055; color: #fff; padding: 5px; font-weight: bold;');
}
if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', initializeSystem); }
else { initializeSystem(); }
</script>