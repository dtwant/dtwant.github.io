<script>
function initializeSystem() {
  const bg = document.querySelector('.cyber-bg');
  const grid = document.querySelector('.cyber-grid');
  const scanline = document.querySelector('.scanline');
  const lock = document.getElementById('sr-lock');
  const hub = document.getElementById('sr-hub');
  const particles = document.querySelectorAll('.sr-particle');
  
  [bg, grid, scanline, lock, hub].forEach(el => { if (el) document.body.appendChild(el); });
  particles.forEach(el => document.body.appendChild(el));
  
  const KEEP = {'HEADER':1,'STYLE':1,'LINK':1,'SCRIPT':1,'NOSCRIPT':1,'META':1};
  Array.from(document.body.children).forEach(el => {
    const ours = el.classList.contains('cyber-bg') || el.classList.contains('cyber-grid') ||
                 el.classList.contains('scanline') || el.classList.contains('sr-particle') ||
                 el.id === 'sr-lock' || el.id === 'sr-hub';
    if (!ours && !KEEP[el.tagName]) el.style.setProperty('display','none','important');
  });

  const TARGET_PIN = "210723";
  let inputCode = "";
  let failCount = 0;
  let lockoutUntil = 0;
  
  const displayEl = document.getElementById('code-display');
  const digits = displayEl.querySelectorAll('.code-digit');
  const msgEl = document.getElementById('lock-msg');
  const lockoutEl = document.getElementById('code-lockout');
  const hubEl = document.getElementById('sr-hub');
  const lockScreen = document.getElementById('sr-lock');

  const updatePINDisplay = () => {
    digits.forEach((d, i) => {
      d.textContent = i < inputCode.length ? '●' : '';
      d.classList.toggle('filled', i < inputCode.length);
    });
  };

  const showLockMessage = (text, isSuccess) => {
    msgEl.textContent = text;
    msgEl.classList.add('show');
    if (isSuccess) msgEl.classList.add('success');
    else msgEl.classList.remove('success');
  };

  const checkLockout = () => {
    if (Date.now() < lockoutUntil) {
      let remaining = Math.ceil((lockoutUntil - Date.now()) / 1000);
      lockoutEl.style.display = 'block';
      lockoutEl.textContent = 'SYSTEM LOCKOUT: ' + remaining + 's REMAINING';
      return true;
    }
    lockoutEl.style.display = 'none';
    return false;
  };

  const verifyPIN = () => {
    if (checkLockout()) { inputCode = ''; updatePINDisplay(); return; }
    if (inputCode === TARGET_PIN) {
      digits.forEach(d => { d.classList.add('success'); });
      showLockMessage('> ACCESS GRANTED', true);
      failCount = 0;
      setTimeout(() => {
        lockScreen.classList.add('unlocked');
        hubEl.classList.add('unlocked');
        runBoot();
      }, 500);
    } else {
      digits.forEach(d => { d.classList.add('error'); });
      showLockMessage('> INVALID ACCESS CODE', false);
      failCount++;
      if (failCount >= 3) {
        lockoutUntil = Date.now() + 30000;
        showLockMessage('> SECURITY LOCKOUT ACTIVATED', false);
      }
      setTimeout(() => {
        inputCode = '';
        updatePINDisplay();
        digits.forEach(d => { d.classList.remove('error'); });
        msgEl.classList.remove('show');
        checkLockout();
      }, 1200);
    }
  };

  document.getElementById('code-keypad').addEventListener('click', function(e) {
    const btn = e.target.closest('.code-key');
    if (!btn) return;
    if (checkLockout()) return;
    const val = btn.dataset.v;
    if (val === 'clear') { inputCode = ''; updatePINDisplay(); }
    else if (val === 'back') { inputCode = inputCode.slice(0, -1); updatePINDisplay(); }
    else if (inputCode.length < 6) {
      inputCode += val;
      updatePINDisplay();
      if (inputCode.length === 6) setTimeout(verifyPIN, 200);
    }
  });

  document.addEventListener('keydown', function(e) {
    if (lockScreen.classList.contains('unlocked')) return;
    if (checkLockout()) return;
    if (e.key >= '0' && e.key <= '9' && inputCode.length < 6) {
      inputCode += e.key; updatePINDisplay();
      if (inputCode.length === 6) setTimeout(verifyPIN, 200);
    } else if (e.key === 'Backspace') {
      inputCode = inputCode.slice(0, -1); updatePINDisplay();
    } else if (e.key === 'Escape') {
      inputCode = ''; updatePINDisplay();
    }
  });

  setInterval(checkLockout, 1000);

  const bootEl = document.getElementById('sr-boot');
  const bootLines = [
    'INITIALIZING SECURE SUBSYSTEM...',
    'LOADING ENCRYPTED MODULES...',
    'VERIFYING CLEARANCE LEVEL...',
    'DECRYPTING ACCESS NODES...',
    'ALL SYSTEMS OPERATIONAL.'
  ];

  const runBoot = () => {
    let i = 0;
    const next = () => {
      if (i >= bootLines.length) {
        bootEl.classList.remove('active');
        bootEl.classList.add('fade');
        return;
      }
      bootEl.textContent = '> ' + bootLines[i];
      bootEl.classList.remove('active');
      void bootEl.offsetWidth;
      bootEl.classList.add('active');
      i++;
      setTimeout(next, 400);
    };
    next();
  };

  const start = Date.now();
  setInterval(() => {
    const s = Math.floor((Date.now() - start) / 1000);
    const el = document.getElementById('sr-uptime');
    if (el) el.textContent =
      String(Math.floor(s/3600)).padStart(2,'0') + ':' +
      String(Math.floor((s%3600)/60)).padStart(2,'0') + ':' +
      String(s%60).padStart(2,'0');
  }, 1000);

  const glitchTargets = document.querySelectorAll('.hex-index, .sr-classification');
  glitchTargets.forEach(target => {
    const orig = target.textContent;
    const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&_';
    let iter = 0;
    const iv = setInterval(() => {
      target.textContent = orig.split('').map((ch, idx) => {
        if (idx < iter) return orig[idx];
        if (ch === ' ' || ch === '─' || ch === '▲') return ch;
        return chars[Math.floor(Math.random() * chars.length)];
      }).join('');
      if (iter >= orig.length) clearInterval(iv);
      iter += 0.5;
    }, 30);
  });
}

if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', initializeSystem); }
else { initializeSystem(); }
</script>