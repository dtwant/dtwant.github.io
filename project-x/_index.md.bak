<circle cx="24" cy="30" r="3" stroke="var(--accent)" stroke-width="2" fill="none"/>
<path d="M16 22V14c0-4.4 3.6-8 8-8s8 3.6 8 8v8" stroke="var(--accent)" stroke-width="2" fill="none"/>
