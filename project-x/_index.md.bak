---
title: "SYSTEM ROOT"
draft: false
layout: "simple"
showTableOfContents: false
showRelated: false
showDate: false
showAuthor: false
showReadingTime: false
robots: "noindex, nofollow"
---

<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Orbitron:wght@400;500;700;900&family=Share+Tech+Mono&family=Zen+Kaku+Gothic+New:wght@400;700&display=swap" rel="stylesheet">

<style>
/* === RESET & CONFIG === */
:root {
  --cyan: #00f3ff;
  --pink: #ff0055;
  --green: #00ff66;
  --purple: #bc13fe;
  --amber: #ffaa00;
  --dark: #030308;
  --card-bg: rgba(3, 3, 12, 0.75);
  --border-dim: rgba(0, 255, 102, 0.15);
  --border-bright: rgba(0, 255, 102, 0.4);
}
h1:not(.sr-title) { display: none !important; }
body {
  margin: 0; padding: 0;
  background: var(--dark) !important;
  color: #e0f8ff;
  font-family: 'JetBrains Mono', monospace;
  overflow-x: hidden;
  width: 100vw;
  min-height: 100vh;
}
*, *::before, *::after { box-sizing: border-box; }

/* === BACKGROUND (COMMAND PORTED) === */
.cyber-bg {
  position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0;
  overflow: hidden; background: #0a0518;
}
.cyber-bg-image {
  position: absolute; inset: -5%; width: 110%; height: 110%;
  background-image: url('/img/cmd_center_bg.png');
  background-size: cover; background-position: center;
  filter: brightness(0.7) contrast(1.15) saturate(1.4);
}
.cyber-bg-vignette {
  position: absolute; inset: 0;
  background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.7) 100%);
}
.cyber-grid {
  position: fixed; top: -50%; left: -50%; width: 200vw; height: 200vh;
  background: linear-gradient(transparent 0%, rgba(0, 255, 102, 0.05) 1%, transparent 2%),
              linear-gradient(90deg, transparent 0%, rgba(188, 19, 254, 0.05) 1%, transparent 2%);
  background-size: 40px 40px;
  transform: perspective(300px) rotateX(60deg) translateY(0) translateZ(-100px);
  animation: grid-move 8s linear infinite;
  z-index: 1; pointer-events: none;
}
@keyframes grid-move {
  0% { transform: perspective(300px) rotateX(60deg) translateY(0) translateZ(-100px); }
  100% { transform: perspective(300px) rotateX(60deg) translateY(40px) translateZ(-100px); }
}
.scanline {
  position: fixed; top: 0; left: 0; width: 100%; height: 100%;
  background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,0) 50%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.2));
  background-size: 100% 3px; pointer-events: none; z-index: 100;
  opacity: 0.12; mix-blend-mode: overlay;
}

/* Floating particles */
.sr-particle {
  position: fixed; z-index: 4; pointer-events: none;
  width: 2px; height: 2px; border-radius: 50%;
  background: var(--cyan);
  box-shadow: 0 0 6px var(--cyan);
  opacity: 0;
  animation: sr-float var(--d, 4s) var(--delay, 0s) ease-in-out infinite;
  left: var(--x, 50%); top: var(--y, 50%);
}
@keyframes sr-float {
  0%   { opacity: 0; transform: translateY(0) translateX(0); }
  20%  { opacity: var(--o, 0.6); }
  80%  { opacity: var(--o, 0.6); }
  100% { opacity: 0; transform: translateY(-40px) translateX(15px); }
}

/* === 6DIGIT PIN LOCK SCREEN === */
#sr-lock {
  position: fixed; inset: 0; z-index: 9999;
  background: rgba(3, 3, 12, 0.92);
  backdrop-filter: blur(12px);
  display: flex; flex-direction: column;
  justify-content: center; align-items: center;
  transition: opacity 0.8s, visibility 0.8s;
}
#sr-lock.unlocked { opacity: 0; visibility: hidden; pointer-events: none; }
#sr-lock::before {
  content: '';
  position: absolute; inset: 0;
  background: repeating-linear-gradient(
    0deg, rgba(0, 0, 0, 0.15) 0px, rgba(0, 0, 0, 0.15) 1px,
    transparent 1px, transparent 2px
  );
  pointer-events: none;
}

.lock-box {
  width: 90%; max-width: 380px;
  background: rgba(2, 2, 15, 0.85);
  border: 1px solid var(--cyan);
  box-shadow: 0 0 40px rgba(0, 243, 255, 0.12), inset 0 0 30px rgba(0, 243, 255, 0.05);
  padding: 3rem 2rem 2rem; position: relative;
  text-align: center;
  display: flex; flex-direction: column; align-items: center;
}
.lock-box::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--pink), var(--cyan), transparent);
  background-size: 200% 100%;
  animation: lock-scan 3s linear infinite;
}
@keyframes lock-scan { from { background-position: 100% 0; } to { background-position: -100% 0; } }

.lock-badge {
  position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
  background: #030308; padding: 4px 16px;
  font-family: 'Orbitron', sans-serif; font-size: 0.8rem;
  color: var(--pink); letter-spacing: 2px;
  border: 1px solid var(--pink); white-space: nowrap;
}
.lock-text {
  margin: 0 0 0.5rem; font-size: 0.9rem; line-height: 1.6;
  color: var(--cyan); text-shadow: 0 0 5px rgba(0, 243, 255, 0.5);
}
.lock-text .pink { color: var(--pink); text-shadow: 0 0 5px rgba(255, 0, 85, 0.5); font-weight: bold; }
.lock-text .blink { animation: blink-c 1s step-end infinite; }
@keyframes blink-c { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

/* PIN Display Styles */
.code-display {
  display: flex; justify-content: center; gap: 8px;
  margin: 1.5rem 0;
}
.code-digit {
  width: 36px; height: 44px;
  background: rgba(0, 243, 255, 0.05);
  border: 1px solid var(--border-dim);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Orbitron', sans-serif;
  font-size: 1.4rem; font-weight: 700;
  color: var(--cyan);
  text-shadow: 0 0 8px rgba(0, 243, 255, 0.6);
  transition: all 0.2s;
}
.code-digit.filled {
  border-color: var(--cyan);
  background: rgba(0, 243, 255, 0.1);
  box-shadow: 0 0 10px rgba(0, 243, 255, 0.2);
}
.code-digit.error {
  border-color: var(--pink);
  color: var(--pink);
  text-shadow: 0 0 8px rgba(255, 0, 85, 0.6);
  animation: code-shake 0.3s;
}
.code-digit.success {
  border-color: var(--green);
  color: var(--green);
  text-shadow: 0 0 8px rgba(0, 255, 102, 0.6);
}
@keyframes code-shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-4px); } 75% { transform: translateX(4px); } }

/* Keypad Styles */
.code-keypad {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 8px; width: 100%; max-width: 260px; margin: 0 auto;
}
.code-key {
  background: rgba(0, 243, 255, 0.04);
  border: 1px solid var(--border-dim);
  color: #e0f8ff;
  font-family: 'Orbitron', sans-serif;
  font-size: 1.1rem; font-weight: 700;
  padding: 12px 0; cursor: pointer;
  transition: all 0.15s;
  -webkit-tap-highlight-color: transparent;
}
.code-key:hover {
  background: rgba(0, 243, 255, 0.1);
  border-color: var(--cyan);
  color: #fff;
  box-shadow: 0 0 10px rgba(0, 243, 255, 0.15);
}
.code-key:active {
  transform: scale(0.95);
  background: rgba(0, 243, 255, 0.15);
}
.code-key.fn {
  font-size: 0.7rem; letter-spacing: 1px;
  color: rgba(160, 185, 210, 0.6);
}
.code-key.fn:hover { color: var(--pink); border-color: var(--pink); }

.lock-msg {
  margin-top: 1rem; height: 1.2em;
  font-family: 'Orbitron', sans-serif; font-size: 0.8rem;
  color: var(--pink); text-shadow: 0 0 5px rgba(255, 0, 85, 0.5);
  opacity: 0; transition: opacity 0.3s;
}
.lock-msg.show { opacity: 1; animation: glitch-shake 0.2s 3; }
.lock-msg.success { color: var(--green); text-shadow: 0 0 5px rgba(0, 255, 102, 0.5); }
@keyframes glitch-shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-3px); }
  75% { transform: translateX(3px); }
}

.code-lockout {
  font-family: 'Orbitron', sans-serif; font-size: 0.7rem;
  color: var(--pink); margin-top: 0.5rem;
  text-shadow: 0 0 5px rgba(255, 0, 85, 0.5);
}

/* === HUB (post-unlock) === */
.sr-hub {
  position: fixed;
  top: 0; left: 0; width: 100vw; height: 100vh;
  overflow-y: auto; overflow-x: hidden;
  z-index: 10;
  display: flex; flex-direction: column; align-items: center;
  padding: 3rem 1.5rem 4rem;
  filter: blur(8px); opacity: 0.3;
  transition: all 1s ease-out;
  scrollbar-width: thin;
  scrollbar-color: var(--pink) transparent;
}
.sr-hub.unlocked { filter: blur(0); opacity: 1; }
.sr-hub::-webkit-scrollbar { width: 4px; }
.sr-hub::-webkit-scrollbar-thumb { background: var(--pink); border-radius: 2px; }
.sr-hub-inner {
  width: 100%; max-width: 960px;
  background: rgba(3, 3, 12, 0.65);
  border-left: 1px solid rgba(0, 255, 102, 0.2);
  border-right: 1px solid rgba(0, 255, 102, 0.2);
  box-shadow: 0 0 80px rgba(0, 0, 0, 0.9);
  backdrop-filter: blur(4px);
  padding: 2rem 2.5rem;
}

/* Header */
.sr-header {
  text-align: center; margin-bottom: 3rem;
  padding: 2.5rem 2rem; position: relative;
  border: 1px solid var(--border-dim);
  background: var(--card-bg);
  overflow: hidden;
}
.sr-header::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: linear-gradient(90deg, transparent, var(--cyan), var(--pink), transparent);
}
.sr-header::after {
  content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--border-bright), transparent);
}

.sr-title {
  font-family: 'Orbitron', sans-serif;
  font-size: clamp(1.4rem, 5vw, 2.8rem); font-weight: 900;
  color: #fff; letter-spacing: 0.15em;
  margin: 0 0 0.5rem;
  text-shadow: 0 0 20px rgba(0, 243, 255, 0.4), 0 0 40px rgba(0, 243, 255, 0.15);
  position: relative;
  animation: sr-glitch-skew 4s infinite linear;
}
.sr-title::before, .sr-title::after {
  content: attr(data-text);
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
}
.sr-title::before { color: var(--pink); z-index: -1; animation: sr-glitch1 0.3s infinite alternate-reverse; opacity: 0.7; }
.sr-title::after { color: var(--cyan); z-index: -2; animation: sr-glitch2 0.3s infinite alternate-reverse; opacity: 0.5; }
@keyframes sr-glitch-skew {
  0%, 95%, 100% { transform: skew(0deg); }
  96% { transform: skew(2deg); }
  97% { transform: skew(-1deg); }
}
@keyframes sr-glitch1 {
  0% { clip-path: inset(20% 0 80% 0); transform: translate(-2px, 1px); }
  100% { clip-path: inset(60% 0 10% 0); transform: translate(2px, -1px); }
}
@keyframes sr-glitch2 {
  0% { clip-path: inset(10% 0 60% 0); transform: translate(1px, -1px); }
  100% { clip-path: inset(80% 0 20% 0); transform: translate(-1px, 1px); }
}

.sr-subtitle {
  font-family: 'Share Tech Mono', monospace;
  font-size: clamp(0.6rem, 2vw, 0.85rem); color: rgba(0, 243, 255, 0.7);
  letter-spacing: 0.2em; margin: 0;
}
.sr-subtitle::before { content: '[ '; color: var(--pink); }
.sr-subtitle::after { content: ' ]'; color: var(--pink); }

/* Status bar */
.sr-status {
  display: flex; justify-content: center; align-items: center;
  gap: 1.5rem; flex-wrap: wrap;
  margin-top: 1.5rem; padding-top: 1rem;
  border-top: 1px solid var(--border-dim);
  font-family: 'Share Tech Mono', monospace;
  font-size: clamp(0.6rem, 1.5vw, 0.75rem); color: rgba(0, 243, 255, 0.5);
}
.sr-stat { display: flex; align-items: center; gap: 0.4rem; white-space: nowrap; }
.sr-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--green); box-shadow: 0 0 6px var(--green);
  animation: sr-pulse 2s infinite; flex-shrink: 0;
}
.sr-dot.purple { background: var(--purple); box-shadow: 0 0 6px var(--purple); }
.sr-dot.amber { background: var(--amber); box-shadow: 0 0 6px var(--amber); }
.sr-dot.cyan { background: var(--cyan); box-shadow: 0 0 6px var(--cyan); }
@keyframes sr-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

/* === HEX GRID / HEX TILE (PORTED FROM 0723 & CUSTOMIZED) === */
.hex-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1.2rem;
  margin-bottom: 3rem;
}

.hex-tile {
  display: block;
  text-decoration: none !important;
  position: relative;
  overflow: hidden;
  border: 1px solid var(--border-dim);
  background: rgba(2, 2, 8, 0.75);
  padding: 1.2rem;
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  clip-path: polygon(8% 0%, 92% 0%, 100% 15%, 100% 85%, 92% 100%, 8% 100%, 0% 85%, 0% 15%);
  min-height: 150px;
  cursor: pointer;
  backdrop-filter: blur(8px);
}
.hex-tile::before {
  content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.05), transparent);
  transition: left 0.5s;
}
.hex-tile:hover {
  border-color: var(--accent, var(--cyan));
  background: var(--hover-bg, rgba(0, 243, 255, 0.05));
  transform: scale(1.04) translateY(-3px);
  box-shadow: 0 0 25px var(--glow, rgba(0, 243, 255, 0.2));
}
.hex-tile:hover::before { left: 100%; }

.hex-inner {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  position: relative;
  z-index: 1;
  height: 100%;
}
.hex-header-row {
  display: flex; justify-content: space-between; align-items: center;
}
.hex-index {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.6rem; color: var(--accent, var(--cyan));
  letter-spacing: 2px;
}
.hex-title-area {
  display: flex; align-items: center; gap: 0.5rem;
}
.hex-icon {
  width: 20px; height: 20px; display: flex; align-items: center; justify-content: center;
}
.hex-icon svg {
  width: 100%; height: 100%; stroke: var(--accent, var(--cyan)); stroke-width: 2; fill: none;
  filter: drop-shadow(0 0 3px var(--glow, rgba(0, 243, 255, 0.5)));
}
.hex-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 0.85rem; font-weight: 700;
  color: #fff; letter-spacing: 1px;
  text-shadow: 0 0 8px var(--glow, rgba(0, 243, 255, 0.3));
}
.hex-tile:hover .hex-title {
  text-shadow: 0 0 12px var(--glow, rgba(0, 243, 255, 0.6));
}
.hex-desc {
  font-family: 'Zen Kaku Gothic New', sans-serif;
  font-size: 0.72rem; color: rgba(200, 220, 240, 0.65);
  line-height: 1.5; margin: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}
.hex-status {
  font-family: 'Orbitron', 'Share Tech Mono', monospace;
  font-size: 0.58rem; color: var(--accent, var(--cyan));
  letter-spacing: 1px; margin-top: auto;
  display: flex; align-items: center; gap: 0.4rem;
}

/* Accent types */
.hex-tile.cmd { --accent: var(--pink); --glow: rgba(255, 0, 85, 0.4); --hover-bg: rgba(255, 0, 85, 0.04); }
.hex-tile.vault { --accent: var(--cyan); --glow: rgba(0, 243, 255, 0.4); --hover-bg: rgba(0, 243, 255, 0.04); }
.hex-tile.timetable { --accent: var(--amber); --glow: rgba(255, 170, 0, 0.4); --hover-bg: rgba(255, 170, 0, 0.04); }
.hex-tile.proof { --accent: var(--cyan); --glow: rgba(0, 243, 255, 0.4); --hover-bg: rgba(0, 243, 255, 0.04); }
.hex-tile.password { --accent: var(--pink); --glow: rgba(255, 0, 85, 0.4); --hover-bg: rgba(255, 0, 85, 0.04); }
.hex-tile.steganography { --accent: var(--green); --glow: rgba(0, 255, 102, 0.4); --hover-bg: rgba(0, 255, 102, 0.04); }
.hex-tile.xbinder { --accent: var(--purple); --glow: rgba(188, 19, 254, 0.4); --hover-bg: rgba(188, 19, 254, 0.04); }


/* Corner frame lines */
.sr-corner {
  position: absolute; width: 10px; height: 10px;
  border-style: solid; pointer-events: none;
  opacity: 0.4; transition: opacity 0.3s;
}
.hex-tile:hover .sr-corner { opacity: 0.8; }
.sr-corner.tl { top: -1px; left: -1px; border-width: 2px 0 0 2px; border-color: var(--accent, var(--cyan)); }
.sr-corner.tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; border-color: var(--accent, var(--cyan)); }
.sr-corner.bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; border-color: var(--accent, var(--cyan)); }
.sr-corner.br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; border-color: var(--accent, var(--cyan)); }

.sr-classification {
  text-align: center; margin-bottom: 2rem; padding: 0.8rem;
  border: 1px solid rgba(255, 0, 85, 0.2); background: rgba(255, 0, 85, 0.03);
  font-family: 'Orbitron', sans-serif; font-size: 0.65rem; letter-spacing: 3px;
  color: var(--pink); opacity: 0.7;
}

.sr-footer { text-align: center; padding-top: 2rem; border-top: 1px solid var(--border-dim); }
.sr-footer-link {
  font-family: 'Share Tech Mono', monospace; font-size: 0.8rem; color: rgba(0, 243, 255, 0.5);
  text-decoration: none; letter-spacing: 0.1em; transition: all 0.3s; padding: 0.6rem 1.2rem;
  border: 1px solid transparent; display: inline-block;
}
.sr-footer-link:hover {
  color: var(--cyan); border-color: var(--cyan); background: rgba(0, 243, 255, 0.05);
  box-shadow: 0 0 15px rgba(0, 243, 255, 0.1);
}
.sr-footer-link::before { content: '> '; color: var(--pink); }

.sr-boot {
  position: fixed; top: 20px; right: 20px;
  font-family: 'Share Tech Mono', monospace; font-size: 0.65rem; color: var(--cyan);
  text-shadow: 0 0 5px rgba(0, 243, 255, 0.5); z-index: 11; pointer-events: none;
  opacity: 0; white-space: nowrap; background: rgba(2, 2, 15, 0.85);
  border: 1px solid rgba(0, 243, 255, 0.3); padding: 4px 10px;
  box-shadow: 0 0 10px rgba(0, 243, 255, 0.1);
}
.sr-boot.active { animation: sr-boot-in 0.3s ease-out forwards; }
.sr-boot.fade { animation: sr-boot-out 0.5s ease-in forwards; }
@keyframes sr-boot-in { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
@keyframes sr-boot-out { from { opacity: 1; } to { opacity: 0; } }

/* === RESPONSIVE RECONSTRUCTIONS === */
@media (max-width: 900px) {
  .sr-hub { padding: 2.5rem 1.2rem 3rem; }
  .sr-hub-inner { padding: 1.5rem 1.5rem; }
  .sr-header { padding: 2rem 1.5rem; margin-bottom: 2rem; }
  .hex-grid { gap: 1rem; }
  .hex-tile { padding: 1rem; min-height: 140px; }
}
@media (max-width: 700px) {
  .sr-hub-inner { border: none; padding: 1rem 0.5rem; background: transparent; box-shadow: none; }
  .hex-grid { grid-template-columns: repeat(2, 1fr); gap: 0.8rem; }
  .hex-tile { min-height: 130px; padding: 0.9rem; clip-path: polygon(6% 0%, 94% 0%, 100% 15%, 100% 85%, 94% 100%, 6% 100%, 0% 85%, 0% 15%); }
  .hex-title { font-size: 0.75rem; }
  .hex-desc { -webkit-line-clamp: 2; font-size: 0.68rem; }
  .sr-header { padding: 1.5rem 1rem; margin-bottom: 1.5rem; }
  .sr-hub { padding: 2rem 1rem 3rem; }
  .lock-box { padding: 2.5rem 1.2rem 1.5rem; }
}
@media (max-width: 500px) {
  .sr-hub { padding: 1.5rem 0.8rem 2.5rem; }
  .sr-header { padding: 1.2rem 0.8rem; margin-bottom: 1.2rem; }
  .hex-grid { grid-template-columns: 1fr; gap: 0.8rem; }
  .hex-tile { clip-path: none; border-radius: 2px; }
  .hex-desc { -webkit-line-clamp: 3; }
  .code-digit { width: 30px; height: 38px; font-size: 1.2rem; }
  .code-keypad { max-width: 200px; gap: 6px; }
  .code-key { font-size: 0.95rem; padding: 10px 0; }
  .lock-box { max-width: 300px; }
}
</style>

<div class="cyber-bg"><div class="cyber-bg-image"></div><div class="cyber-bg-vignette"></div></div>
<div class="cyber-grid"></div>
<div class="scanline"></div>

<div class="sr-particle" style="--x:10%;--y:20%;--d:3.2s;--delay:0s;--o:0.5"></div>
<div class="sr-particle" style="--x:85%;--y:15%;--d:4.1s;--delay:0.5s;--o:0.4"></div>
<div class="sr-particle" style="--x:50%;--y:70%;--d:3.8s;--delay:1s;--o:0.6"></div>
<div class="sr-particle" style="--x:25%;--y:55%;--d:2.9s;--delay:0.3s;--o:0.3"></div>
<div class="sr-particle" style="--x:75%;--y:40%;--d:4.5s;--delay:0.8s;--o:0.5"></div>
<div class="sr-particle" style="--x:15%;--y:80%;--d:3.5s;--delay:1.2s;--o:0.4"></div>
<div class="sr-particle" style="--x:90%;--y:60%;--d:3.0s;--delay:0.2s;--o:0.3"></div>
<div class="sr-particle" style="--x:60%;--y:10%;--d:4.3s;--delay:0.7s;--o:0.5"></div>

<!-- PIN GATE -->
<div id="sr-lock">
<div class="lock-box">
<div class="lock-badge">CLEARANCE REQUIRED</div>
<p class="lock-text">> ENTER 6-DIGIT CORE CODES<span class="blink">_</span></p>
<div class="code-display" id="code-display">
<div class="code-digit" data-i="0"></div>
<div class="code-digit" data-i="1"></div>
<div class="code-digit" data-i="2"></div>
<div class="code-digit" data-i="3"></div>
<div class="code-digit" data-i="4"></div>
<div class="code-digit" data-i="5"></div>
</div>
<div class="code-keypad" id="code-keypad">
<button class="code-key" data-v="1">1</button>
<button class="code-key" data-v="2">2</button>
<button class="code-key" data-v="3">3</button>
<button class="code-key" data-v="4">4</button>
<button class="code-key" data-v="5">5</button>
<button class="code-key" data-v="6">6</button>
<button class="code-key" data-v="7">7</button>
<button class="code-key" data-v="8">8</button>
<button class="code-key" data-v="9">9</button>
<button class="code-key fn" data-v="clear">CLR</button>
<button class="code-key" data-v="0">0</button>
<button class="code-key fn" data-v="back">DEL</button>
</div>
<div class="lock-msg" id="lock-msg">ACCESS DENIED</div>
<div class="code-lockout" id="code-lockout" style="display:none;"></div>
</div>
</div>

